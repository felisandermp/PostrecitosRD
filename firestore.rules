rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuarios autenticados pueden leer/escribir sus datos
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null; // Permitir leer otros usuarios para roles
    }
    
    // Solo usuarios autenticados pueden acceder a productos
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }
    
    // Solo usuarios autenticados pueden acceder a pedidos
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Solo usuarios autenticados pueden acceder a facturas
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }
    
    // Solo usuarios autenticados pueden acceder a movimientos
    match /inventory_movements/{movementId} {
      allow read, write: if request.auth != null;
    }
  }
}